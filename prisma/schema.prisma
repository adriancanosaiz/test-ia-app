generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Folder {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String?
  subjects    Subject[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Subject {
  id          String     @id @default(cuid())
  name        String
  description String?
  folderId    String
  folder      Folder     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

model Document {
  id            String            @id @default(cuid())
  title         String
  fileName      String
  storageKey    String            @unique
  mimeType      String
  status        DocumentStatus    @default(PENDING)
  errorMessage  String?
  chunkCount    Int               @default(0)
  progress      Int               @default(0)
  subjectId     String
  subject       Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  chunks        Chunk[]
  chatSessions  ChatSession[]
  summaries     DocumentSummary[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model DocumentSummary {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content      String
  status       String   @default("PROCESSING")
  progress     Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([documentId])
}

model Chunk {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content     String
  index       Int
  tokenCount  Int?
  pageNumber  Int?
  metadata    Json?
  embedding   Unsupported("vector(768)")?
  createdAt   DateTime  @default(now())

  questions Question[]

  @@index([documentId])
}

enum SourceType {
  FOLDER
  SUBJECT
  DOCUMENT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum TestStatus {
  DRAFT
  READY
  PROCESSING
  ERROR
}

model Test {
  id            String       @id @default(cuid())
  title         String
  description   String?
  questionCount Int
  difficulty    Difficulty
  questionType  QuestionType
  sourceType    SourceType
  sourceId      String
  status        TestStatus   @default(DRAFT)
  progress      Int          @default(0)
  errorMessage  String?
  questions     Question[]
  attempts      TestAttempt[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Question {
  id            String       @id @default(cuid())
  testId        String
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  type          QuestionType
  difficulty    Difficulty
  content       String
  explanation   String?
  isCorrect     Boolean?
  modelAnswer   String?
  sourceChunkId String?
  sourceChunk   Chunk?       @relation(fields: [sourceChunkId], references: [id])
  options       Option[]
  answers       Answer[]
  createdAt     DateTime     @default(now())
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  index      Int
  isCorrect  Boolean  @default(false)
}

model TestAttempt {
  id         String   @id @default(cuid())
  testId     String
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  score      Float?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  answers    Answer[]
}

model Answer {
  id               String      @id @default(cuid())
  attemptId        String
  attempt          TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionId String?
  booleanAnswer    Boolean?
  textAnswer       String?
  isCorrect        Boolean?
  feedback         String?
  createdAt        DateTime    @default(now())
}

model ChatSession {
  id               String        @id @default(cuid())
  title            String?
  sourceDocumentId String?
  sourceDocument   Document?     @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  messages         ChatMessage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  status    String? // "PROCESSING" | "READY" | "ERROR"
  sources   Json?
  createdAt DateTime    @default(now())
}

model ProcessingJob {
  id           String   @id @default(uuid())
  entityType   String // "document", "test", "summary", "chat"
  entityId     String
  status       String // "PENDING", "PROCESSING", "READY", "ERROR", "CANCELLED"
  progress     Int      @default(0)
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  errorMessage String?
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
}

model AppSettings {
  id                String   @id @default(uuid())
  chatProvider      String   // "ollama" | "openai" | "anthropic" | "groq"
  chatModel         String
  embeddingProvider String   // "ollama" inicialmente
  embeddingModel    String
  apiKey            String?  // opcional, para providers de API
  baseUrl           String?  // opcional, para endpoints compatibles
  language          String   @default("es") // "es" | "en"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
