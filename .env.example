# Base de datos (PostgreSQL + pgvector expuesto en puerto 5433 para evitar conflictos)
DATABASE_URL="postgresql://testforge:testforge@localhost:5433/testforge"

# Proveedores de IA (MVP 100% local con Ollama)
EMBEDDING_PROVIDER=ollama
CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:3b

# Configuración resistente de Ollama
# OLLAMA_TIMEOUT_MS=120000                # Timeout por defecto para llamadas rápidas a Ollama (ms)
# OLLAMA_GENERATION_TIMEOUT_MS=300000     # Timeout para generación de tests/resúmenes/chat (ms)
# OLLAMA_EMBEDDING_DIMENSIONS=768         # Debe coincidir con la dimensión del vector en Prisma

# Seguridad opcional: si se define, protege la app con esta contraseña
# LOCK_PASSWORD=
